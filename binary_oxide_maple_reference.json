{
  "_metadata": {
    "title": "Binary Oxide MAPLE Reference Table",
    "description": "Reference MAPLE (Madelung Part of Lattice Energy) values for binary oxides, for use with Hoppe's additivity theorem. Values are in kcal/mol per formula unit.",
    "version": "1.0.0",
    "authors": [
      "Peter Gross",
      "Nik Reeves-McLaren"
    ],
    "associated_paper": "Database-Scale Validation of Hoppe's MAPLE Additivity Theorem for Perovskite and Pyrochlore Oxides",
    "tool": "MaplePy",
    "units": {
      "maple_kcal_mol": "kcal/mol per formula unit",
      "maple_kj_mol": "Not included; multiply kcal/mol by 4.184 to convert"
    },
    "methodology": {
      "icsd_calibrated": "Median MAPLE across qualifying ICSD entries at ambient conditions (273-303 K, <0.15 MPa). High-pressure entries, zero-MAPLE entries, and non-stoichiometric compositions excluded.",
      "validation": "Values from MaplePy benchmark calculations (NaCl, TiO2, BaTiO3).",
      "estimated": "Interpolated from chemical trends within structure type families (e.g., lanthanide contraction in bixbyite RE2O3 series). These carry additional uncertainty and should be updated when ICSD data become available."
    },
    "source_classifications": {
      "icsd_median": "Calibrated from ICSD median (61% of entries, 65 of 107)",
      "validation": "From MaplePy validation structures (5% of entries, 5 of 107)",
      "estimated": "Interpolated or estimated (35% of entries, 37 of 107)"
    },
    "n_entries": 112,
    "licence": "CC-BY-4.0",
    "citation": "Gross, P.; Reeves-McLaren, N. Angew. Chem. Int. Ed., 2026 (submitted)"
  },
  "_field_descriptions": {
    "formula": "Reduced chemical formula of the binary oxide",
    "maple_kcal_mol": "MAPLE value in kcal/mol per formula unit",
    "structure_type": "Crystal structure type and space group",
    "source": "How the value was determined: ICSD median, validation, or estimated",
    "n_icsd_entries": "Number of qualifying ICSD entries used for the median (null if estimated)",
    "icsd_range_min": "Minimum MAPLE across qualifying ICSD entries (null if estimated)",
    "icsd_range_max": "Maximum MAPLE across qualifying ICSD entries (null if estimated)",
    "confidence": "high = ICSD median from >= 10 entries; medium = ICSD median from 2-9 entries or validation; low = estimated/interpolated"
  },
